# Database (SQLite for local dev, MySQL for production)
DB_BACKEND=sqlite
SQLITE_DB_PATH=nfl_data.db
# DB_URL=mysql+pymysql://user:pass@host:3306/nfl_data

# API keys (the UI can start without this, but live-odds pipeline runs fail closed)
ODDS_API_KEY=
NFL_ODDS_MAX_AGE_SECONDS=300
NFL_ODDS_MIN_EVENT_COVERAGE=1.0
NFL_ODDS_MIN_MARKET_COVERAGE=1.0
NFL_ODDS_MIN_SPORTSBOOKS_PER_EVENT_MARKET=2
NFL_ODDS_REQUIRED_MARKETS=player_pass_yds,player_rush_yds,player_rec_yds
# NBA_API_KEY=  # not needed, nba_api is free

# Demo mode (stubs pipeline trigger, uses seed data)
DEMO_MODE=false

# Local services
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# Logging: console for local use, json for deployments
LOG_FORMAT=console
LOG_LEVEL=INFO

# Pipeline control (use a high-entropy server-side token in production)
PIPELINE_CONTROL_TOKEN=
PIPELINE_OPERATOR_TIERS=operator,admin
ENABLE_PIPELINE_SCHEDULER=false
ENABLE_QUEUE_MONITOR=true
PIPELINE_MONITOR_INTERVAL_SECONDS=60
PIPELINE_MAX_QUEUE_AGE_SECONDS=300
