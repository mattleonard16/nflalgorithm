# Database (SQLite for local dev, MySQL for production)
DB_BACKEND=sqlite
SQLITE_DB_PATH=nfl_data.db
# DB_URL=mysql+pymysql://user:pass@host:3306/nfl_data

# API Keys (optional for local dev)
ODDS_API_KEY=
# NBA_API_KEY=  # not needed, nba_api is free

# Demo mode (stubs pipeline trigger, uses seed data)
DEMO_MODE=false

# Server
API_HOST=0.0.0.0
API_PORT=8000

# Pipeline control (use a high-entropy server-side token in production)
PIPELINE_CONTROL_TOKEN=
PIPELINE_OPERATOR_TIERS=operator,admin
ENABLE_PIPELINE_SCHEDULER=false
ENABLE_QUEUE_MONITOR=true
PIPELINE_MONITOR_INTERVAL_SECONDS=60
PIPELINE_MAX_QUEUE_AGE_SECONDS=300
