# Render env vars (set via dashboard, do NOT commit real values).
# Marked `sync: false` in render.yaml so they must be set per-service.

# --- API service (nflalgorithm-api) ---
# Optional: live odds scraping. Omit to disable.
ODDS_API_KEY=

# Comma-separated origins for CORS. Set to the frontend Render URL.
# Example: https://nflalgorithm-frontend.onrender.com
# Unset = falls back to localhost:3000/3001 (dev default).
ALLOWED_ORIGINS=

# --- Frontend service (nflalgorithm-frontend) ---
# Public URL of the API service.
# Example: https://nflalgorithm-api.onrender.com
NEXT_PUBLIC_API_URL=
